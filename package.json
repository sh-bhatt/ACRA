{
  "name": "acra",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@acra/web",
    "dev:web": "npm run dev --workspace=@acra/web",
    "build": "npm run build --workspace=@acra/web",
    "lint": "npm run lint --workspace=@acra/web",
    "dev:worker": "npm run dev --workspace=@acra/worker",
    "build:worker": "npm run build --workspace=@acra/worker",
    "typecheck:worker": "npm run typecheck --workspace=@acra/worker",
    "build:packages": "npm run build --workspace=@acra/database --workspace=@acra/review-schema --workspace=@acra/shared",
    "typecheck:packages": "npm run typecheck --workspace=@acra/database --workspace=@acra/review-schema --workspace=@acra/shared",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck:all": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
